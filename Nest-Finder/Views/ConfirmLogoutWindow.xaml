<Window x:Class="NestFinder.Views.ConfirmLogoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Logout" 
        Height="180" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Border CornerRadius="10" Background="#1C2333" BorderThickness="1" BorderBrush="#2D3748" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" 
                       Text="Confirm Logout" 
                       Foreground="{StaticResource TextPrimaryBrush}" 
                       FontFamily="{StaticResource SegoeUIFont}" 
                       FontSize="18" 
                       FontWeight="Bold"/>

            <!-- Message -->
            <TextBlock Grid.Row="1" 
                       Text="Are you sure you want to logout?" 
                       Foreground="{StaticResource TextMutedBrush}" 
                       FontFamily="{StaticResource SegoeUIFont}" 
                       FontSize="13" 
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,10,0,10"/>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButtonStyle}" 
                        Content="Cancel" 
                        Width="90" 
                        Height="34" 
                        Click="BtnCancel_Click" 
                        Margin="0,0,12,0"/>
                        
                <Button Style="{StaticResource DangerButtonStyle}" 
                        Content="Logout" 
                        Width="90" 
                        Height="34" 
                        Click="BtnLogout_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
