<mah:MetroWindow x:Class="NestFinder.Views.MarkAsPaidDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="Mark Payment as Paid"
        Width="400"
        Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117"
        GlowBrush="#00FFC8"
        ShowTitleBar="True"
        TitleForeground="White"
        BorderThickness="1"
        BorderBrush="#2D3748">

    <StackPanel Margin="24,20">

        <!-- Transaction info summary -->
        <Border Background="#1C2333"
                CornerRadius="8"
                Padding="14,12"
                BorderBrush="#2D3748"
                BorderThickness="1"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock x:Name="TxSummaryText"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Margin="0,0,0,4"/>
                <!-- Set in code: "House — $250,000 — John Doe" -->
                <TextBlock x:Name="TxAmountText"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#00FFC8"/>
                <!-- Set in code: "$250,000" -->
            </StackPanel>
        </Border>

        <!-- Payment method selector -->
        <TextBlock Text="PAYMENT RECEIVED VIA"
                   FontSize="10"
                   FontWeight="SemiBold"
                   Foreground="#8B949E"
                   Margin="0,0,0,8"/>

        <!-- Two toggle buttons: Cash | Online -->
        <StackPanel Orientation="Horizontal" 
                    Margin="0,0,0,24">

            <Border x:Name="CashBorder"
                    CornerRadius="8"
                    BorderThickness="2"
                    BorderBrush="#00FFC8"
                    Background="#00FFC820"
                    Padding="20,10"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    MouseLeftButtonDown="SelectCash">
                <StackPanel HorizontalAlignment="Center">
                    <fa:IconImage x:Name="CashIcon"
                                  Icon="MoneyBill"
                                  Width="24" Height="24"
                                  Foreground="#00FFC8"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,6"/>
                    <TextBlock x:Name="CashText"
                               Text="Cash"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#00FFC8"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border x:Name="OnlineBorder"
                    CornerRadius="8"
                    BorderThickness="2"
                    BorderBrush="#2D3748"
                    Background="Transparent"
                    Padding="20,10"
                    Cursor="Hand"
                    MouseLeftButtonDown="SelectOnline">
                <StackPanel HorizontalAlignment="Center">
                    <fa:IconImage x:Name="OnlineIcon"
                                  Icon="CreditCard"
                                  Width="24" Height="24"
                                  Foreground="#8B949E"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,6"/>
                    <TextBlock x:Name="OnlineText"
                               Text="Online"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#8B949E"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- Divider -->
        <Border Height="1" 
                Background="#2D3748" 
                Margin="0,16,0,16"/>

        <!-- Bottom buttons -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Cancel"
                    Style="{StaticResource OutlineButton}"
                    Height="40"
                    FontSize="13"
                    Click="Cancel_Click"/>

            <Button Grid.Column="2"
                    x:Name="ConfirmBtn"
                    Height="40"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Background="#00FFC8"
                    Foreground="#0D1117"
                    BorderThickness="0"
                    Content="Confirm Payment"
                    Click="ConfirmPayment_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" 
                                Value="#00FFC8"/>
                        <Setter Property="Foreground" 
                                Value="#0D1117"/>
                        <Setter Property="FontWeight" 
                                Value="SemiBold"/>
                        <Setter Property="BorderThickness" 
                                Value="0"/>
                        <Setter Property="Cursor" 
                                Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter Property="Background" 
                                        Value="#00E6B4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" 
                                     Value="False">
                                <Setter Property="Background" 
                                        Value="#2D3748"/>
                                <Setter Property="Foreground" 
                                        Value="#4A5568"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </StackPanel>
</mah:MetroWindow>
