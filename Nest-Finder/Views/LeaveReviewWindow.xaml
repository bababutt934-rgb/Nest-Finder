<mah:MetroWindow x:Class="NestFinder.Views.LeaveReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:icon="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="Nest Finder - Leave a Review" 
        Height="320" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource MainBgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        BorderThickness="0"
        GlowBrush="{StaticResource AccentTealBrush}"
        ShowTitleBar="False"
        WindowStyle="None">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/assets/customer_bg.jpg" Stretch="UniformToFill" Opacity="0.12"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="50" />
            <!-- Content -->
            <RowDefinition Height="*" />
            <!-- Footer -->
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>
        <Border Background="#260D1117" Grid.RowSpan="3"/>

        <!-- Header -->
        <Border Grid.Row="0" Background="#EC161B22" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <icon:IconImage Icon="Star" Foreground="{StaticResource AccentTealBrush}" Width="18" Height="18"/>
                    <TextBlock Text="Leave a Review" Foreground="White" FontFamily="{StaticResource SegoeUIFont}" FontSize="16" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource TitlebarButtonStyle}" Width="32" Height="32" Click="BtnCancel_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right">
                    <icon:IconImage Icon="Times" Foreground="{StaticResource TextPrimaryBrush}" Width="12" Height="12"/>
                </Button>
            </Grid>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="20">
            <!-- Rating star selectors -->
            <TextBlock Text="YOUR RATING" Foreground="{StaticResource TextMutedBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
            <WrapPanel x:Name="StarsPanel" Margin="0,0,0,15">
                <icon:IconBlock Icon="Star" FontSize="28" Foreground="{StaticResource TextMutedBrush}" Cursor="Hand" MouseLeftButtonDown="Star_Click" Tag="1" Margin="0,0,12,0"/>
                <icon:IconBlock Icon="Star" FontSize="28" Foreground="{StaticResource TextMutedBrush}" Cursor="Hand" MouseLeftButtonDown="Star_Click" Tag="2" Margin="0,0,12,0"/>
                <icon:IconBlock Icon="Star" FontSize="28" Foreground="{StaticResource TextMutedBrush}" Cursor="Hand" MouseLeftButtonDown="Star_Click" Tag="3" Margin="0,0,12,0"/>
                <icon:IconBlock Icon="Star" FontSize="28" Foreground="{StaticResource TextMutedBrush}" Cursor="Hand" MouseLeftButtonDown="Star_Click" Tag="4" Margin="0,0,12,0"/>
                <icon:IconBlock Icon="Star" FontSize="28" Foreground="{StaticResource TextMutedBrush}" Cursor="Hand" MouseLeftButtonDown="Star_Click" Tag="5"/>
            </WrapPanel>

            <!-- Comments -->
            <TextBlock Text="COMMENT" Foreground="{StaticResource TextMutedBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtComment" Style="{StaticResource DarkTextBoxStyle}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#EC161B22" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Cancel" Width="90" Height="34" Click="BtnCancel_Click" Margin="0,0,12,0"/>
                <Button Style="{StaticResource PrimaryButtonStyle}" Content="Submit Review" Width="130" Height="34" Click="BtnSubmit_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</mah:MetroWindow>
