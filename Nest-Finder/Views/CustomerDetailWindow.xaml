<mah:MetroWindow x:Class="NestFinder.Views.CustomerDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="Customer Profile"
        Width="680"
        Height="560"
        MinWidth="620"
        MinHeight="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117"
        ShowTitleBar="True"
        TitleForeground="White"
        GlowBrush="#00FFC8"
        BorderThickness="1"
        BorderBrush="#2D3748"
        Foreground="{StaticResource TextPrimaryBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main Content Area -->
        <StackPanel Grid.Row="0" Margin="20,16,20,16">

            <!-- SECTION 1: PROFILE HEADER CARD -->
            <Border Background="#1C2333"
                    CornerRadius="10"
                    Padding="20,16"
                    Margin="0,0,0,12"
                    BorderBrush="#2D3748"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar Circle (initials) -->
                    <Border Grid.Column="0"
                            Width="60" Height="60"
                            CornerRadius="30"
                            Background="#6C5CE7"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="AvatarInitials"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Name + Role badge + Status badge -->
                    <StackPanel Grid.Column="1" 
                                VerticalAlignment="Center">
                        <TextBlock x:Name="CustomerNameText"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,6"/>

                        <StackPanel Orientation="Horizontal">
                            <!-- Role badge: always "Customer" purple -->
                            <Border Background="#6C5CE720"
                                    BorderBrush="#6C5CE7"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,2"
                                    Margin="0,0,8,0">
                                <TextBlock Text="Customer"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#6C5CE7"/>
                            </Border>

                            <!-- Status badge: Active=teal, Inactive=red -->
                            <Border x:Name="StatusBadgeBorder"
                                    CornerRadius="4"
                                    Padding="8,2">
                                <TextBlock x:Name="StatusBadgeText"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Quick stats chips (right side) -->
                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">

                        <!-- Total Transactions chip -->
                        <Border Background="#1C2333"
                                BorderBrush="#2D3748"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,6"
                                Margin="0,0,0,6">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="TotalTxText"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#00FFC8"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Transactions"
                                           FontSize="10"
                                           Foreground="#8B949E"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Member Since chip -->
                        <Border Background="#1C2333"
                                BorderBrush="#2D3748"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,6">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="MemberSinceText"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Member Since"
                                           FontSize="10"
                                           Foreground="#8B949E"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- SECTION 2: CONTACT INFO CARD (2x2 grid of detail items) -->
            <Border Background="#1C2333"
                    CornerRadius="10"
                    Padding="20,14"
                    Margin="0,0,0,12"
                    BorderBrush="#2D3748"
                    BorderThickness="1">
                <StackPanel>

                    <!-- Section label with accent bar -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" Height="14"
                                Background="#00FFC8"
                                CornerRadius="2"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Contact Information"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#8B949E"/>
                    </StackPanel>

                    <!-- 2-column info grid -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Email -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <fa:IconImage Icon="Envelope"
                                          Width="14" Height="14"
                                          Foreground="#8B949E"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="EMAIL"
                                           FontSize="9"
                                           Foreground="#4A5568"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="EmailText"
                                           FontSize="13"
                                           Foreground="White"
                                           TextWrapping="NoWrap"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Phone -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <fa:IconImage Icon="Phone"
                                          Width="14" Height="14"
                                          Foreground="#8B949E"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="PHONE"
                                           FontSize="9"
                                           Foreground="#4A5568"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="PhoneText"
                                           FontSize="13"
                                           Foreground="White"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- SECTION 3: TRANSACTION HISTORY CARD (fills remaining space) -->
            <Border Background="#1C2333"
                    CornerRadius="10"
                    Padding="20,14"
                    Margin="0,0,0,12"
                    BorderBrush="#2D3748"
                    BorderThickness="1">
                <StackPanel>

                    <!-- Section label -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" Height="14"
                                Background="#F0A500"
                                CornerRadius="2"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Transaction History"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#8B949E"/>
                    </StackPanel>

                    <!-- DataGrid — max height to prevent overflow -->
                    <DataGrid x:Name="TransactionsGrid"
                              Style="{StaticResource DarkDataGrid}"
                              MaxHeight="160"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              CanUserResizeColumns="False"
                              CanUserSortColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PROPERTY"
                                                Binding="{Binding PropertyTitle}"
                                                Width="*"/>
                            <DataGridTextColumn Header="TYPE"
                                                Binding="{Binding TransactionType}"
                                                Width="60"/>
                            <DataGridTextColumn Header="AMOUNT"
                                                Binding="{Binding AmountFormatted}"
                                                Width="90"/>
                            <DataGridTextColumn Header="DATE"
                                                Binding="{Binding DateFormatted}"
                                                Width="90"/>
                            <DataGridTemplateColumn Header="STATUS" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4"
                                                Padding="6,2"
                                                HorizontalAlignment="Center"
                                                Background="{Binding StatusBadgeBg}"
                                                BorderBrush="{Binding StatusBadgeBorder}"
                                                BorderThickness="1">
                                            <TextBlock 
                                                Text="{Binding Status}"
                                                Foreground="{Binding StatusBadgeText}"
                                                FontSize="11"
                                                FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state when no transactions -->
                    <Border x:Name="NoTxPanel"
                            Padding="16"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                            <fa:IconImage Icon="Receipt"
                                          Width="16" Height="16"
                                          Foreground="#4A5568"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="No transactions found for this customer."
                                       FontSize="12"
                                       Foreground="#4A5568"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

        </StackPanel>

        <!-- BOTTOM ACTION BAR -->
        <Border Grid.Row="1"
                Background="#161B22"
                BorderBrush="#2D3748"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Account action message -->
                <TextBlock x:Name="ActionHintText"
                           Grid.Column="0"
                           FontSize="11"
                           Foreground="#8B949E"
                           VerticalAlignment="Center"/>

                <!-- Toggle Status button — dynamic text + color -->
                <Button Grid.Column="1"
                        x:Name="ToggleStatusBtn"
                        Height="38"
                        Width="160"
                        FontSize="13"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Click="ToggleStatus_Click"/>

                <!-- Close button -->
                <Button Grid.Column="3"
                        Content="Close"
                        Style="{StaticResource OutlineButton}"
                        Height="38"
                        Width="100"
                        Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>
