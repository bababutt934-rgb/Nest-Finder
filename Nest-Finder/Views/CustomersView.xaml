<UserControl x:Class="NestFinder.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
             xmlns:icon="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="{StaticResource MainBgBrush}">

    <Grid Margin="30,30,20,20">
        <Grid.RowDefinitions>
            <!-- Title Bar -->
            <RowDefinition Height="Auto" />
            <!-- Search -->
            <RowDefinition Height="Auto" />
            <!-- Grid -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="MANAGE CUSTOMERS" 
                       Foreground="{StaticResource TextPrimaryBrush}" 
                       FontFamily="{StaticResource SegoeUIFont}" 
                       FontSize="28" 
                       FontWeight="Bold"/>
            <TextBlock Text="View customer details and activate/deactivate user accounts." 
                       Foreground="{StaticResource TextMutedBrush}" 
                       FontFamily="{StaticResource SegoeUIFont}" 
                       FontSize="13" 
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Search Controls -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtSearch" 
                         Grid.Column="0" 
                         Style="{StaticResource DarkTextBoxStyle}" 
                         Height="36" 
                         Tag="Search by name or email..." 
                         GotFocus="TxtSearch_GotFocus" 
                         LostFocus="TxtSearch_LostFocus" 
                         Foreground="{StaticResource TextPrimaryBrush}"/>

                <Button Grid.Column="2" 
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Content="Search" 
                        Width="100" 
                        Height="36" 
                        Click="BtnSearch_Click"/>
            </Grid>
        </Border>

        <!-- Customers Grid -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="15">
            <DataGrid x:Name="CustomersGrid"
                      AutoGenerateColumns="False"
                      Background="Transparent"
                      RowBackground="#1C2333"
                      AlternatingRowBackground="#161B22"
                      BorderThickness="0"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      RowHeaderWidth="0"
                      SelectionMode="Single"
                      RowHeight="46"
                      CanUserAddRows="False">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#0D1117" />
                        <Setter Property="Foreground" Value="#8B949E" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="Padding" Value="10,8" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D3748" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#6C5CE7" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                    <DataGridTextColumn Header="FULL NAME" Binding="{Binding FullName}" Width="2*" />
                    <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="2.5*" />
                    <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}" Width="1.5*" />
                    <DataGridTextColumn Header="ROLE" Binding="{Binding Role}" Width="1.2*" />
                    
                    <!-- Status column -->
                    <DataGridTemplateColumn Header="STATUS" Width="1.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="8,3" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="#2000FFC8" />
                                                    <Setter Property="BorderBrush" Value="#00FFC8" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Background" Value="#20FF4C4C" />
                                                    <Setter Property="BorderBrush" Value="#FF4C4C" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="Active" FontSize="11" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#00FFC8" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Text" Value="Inactive" />
                                                        <Setter Property="Foreground" Value="#FF4C4C" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Joined Column -->
                    <DataGridTextColumn Header="JOINED" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="1.2*" />

                    <!-- Actions Column -->
                    <DataGridTemplateColumn Header="ACTIONS" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="View Profile" 
                                            Style="{StaticResource PrimaryButtonStyle}" 
                                            Height="28" Padding="10,2" Margin="0,0,8,0"
                                            Click="BtnViewProfile_Click"
                                            Tag="{Binding}"/>
                                            
                                    <Button Content="Toggle Status" 
                                            Style="{StaticResource SecondaryButtonStyle}" 
                                            Height="28" Padding="10,2"
                                            Click="BtnToggleActive_Click"
                                            Tag="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
