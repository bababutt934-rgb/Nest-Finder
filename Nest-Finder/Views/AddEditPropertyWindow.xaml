<mah:MetroWindow x:Class="NestFinder.Views.AddEditPropertyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="Add Property"
        Width="780"
        Height="620"
        MinWidth="700"
        MinHeight="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117"
        ShowTitleBar="True"
        TitleForeground="White"
        GlowBrush="#00FFC8"
        BorderThickness="1"
        BorderBrush="#2D3748"
        Foreground="{StaticResource TextPrimaryBrush}">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/assets/admin_bg.jpg" Stretch="UniformToFill" Opacity="0.22"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#260D1117" Grid.RowSpan="3"/>

        <!-- ROW 0: Page Icon + Title header inside dialog -->
        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal" 
                    Margin="24,16,24,0">
            <fa:IconImage Icon="Building" 
                          Width="22" Height="22" 
                          Foreground="#00FFC8" 
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>
            <TextBlock x:Name="DialogTitle"
                       Text="Edit Property"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ROW 1: ScrollViewer wrapping all form fields -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Margin="24,12,24,0"
                      Padding="0,0,6,0">
            <StackPanel>

                <!-- SECTION 1: BASIC INFORMATION -->
                <Border Background="#1C2333" 
                        CornerRadius="8" 
                        Padding="16,14"
                        Margin="0,0,0,12">
                    <Border.BorderBrush>#2D3748</Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>

                        <!-- Section Label with left accent bar -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="3" Height="16" 
                                    Background="#00FFC8" 
                                    CornerRadius="2"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="Basic Information"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#8B949E"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Row 1: Title (full width) -->
                        <TextBlock Text="Title" 
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TitleBox"
                                 Style="{StaticResource DarkTextBox}"
                                 Margin="0,4,0,12"
                                 mah:TextBoxHelper.Watermark="e.g. Modern 3-Bedroom House"/>

                        <!-- Row 2: City | Price side by side -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="City" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="CityBox"
                                         Style="{StaticResource DarkTextBox}"
                                         Margin="0,4,0,0"
                                         mah:TextBoxHelper.Watermark="e.g. Lahore"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Price ($)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="PriceBox"
                                         Style="{StaticResource DarkTextBox}"
                                         Margin="0,4,0,0"
                                         mah:TextBoxHelper.Watermark="e.g. 250000"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 3: Type | Status side by side -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Type" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="TypeBox"
                                          Style="{StaticResource DarkComboBox}"
                                          Margin="0,4,0,0">
                                    <ComboBoxItem Content="Residential"/>
                                    <ComboBoxItem Content="Commercial"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Status" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="StatusBox"
                                          Style="{StaticResource DarkComboBox}"
                                          Margin="0,4,0,0">
                                    <ComboBoxItem Content="Available"/>
                                    <ComboBoxItem Content="Sold"/>
                                    <ComboBoxItem Content="Rented"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- Row 4: Area Size (single field) -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Area Size (sqft)" 
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="AreaBox"
                                         Style="{StaticResource DarkTextBox}"
                                         Margin="0,4,0,0"
                                         mah:TextBoxHelper.Watermark="e.g. 1200"/>
                            </StackPanel>
                            <!-- Column 2 intentionally empty for balance -->
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- SECTION 2: PROPERTY DETAILS -->
                <Border Background="#1C2333"
                        CornerRadius="8"
                        Padding="16,14"
                        Margin="0,0,0,12">
                    <Border.BorderBrush>#2D3748</Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>

                        <!-- Section Label -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="3" Height="16"
                                    Background="#6C5CE7"
                                    CornerRadius="2"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="Property Details"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#8B949E"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Bedrooms | Bathrooms — clean numeric TextBox, NO custom +/- spinners -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Bedrooms" 
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="BedroomsBox"
                                         Style="{StaticResource DarkTextBox}"
                                         Margin="0,4,0,0"
                                         mah:TextBoxHelper.Watermark="e.g. 3"
                                         MaxLength="2"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Bathrooms" 
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="BathroomsBox"
                                         Style="{StaticResource DarkTextBox}"
                                         Margin="0,4,0,0"
                                         mah:TextBoxHelper.Watermark="e.g. 2"
                                         MaxLength="2"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"/>
                            </StackPanel>
                        </Grid>

                        <!-- Description -->
                        <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="DescriptionBox"
                                 Style="{StaticResource DarkTextBox}"
                                 Margin="0,4,0,0"
                                 Height="90"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 mah:TextBoxHelper.Watermark="Describe the property..."/>

                    </StackPanel>
                </Border>

                <!-- SECTION 3: PROPERTY IMAGES -->
                <Border Background="#1C2333"
                        CornerRadius="8"
                        Padding="16,14"
                        Margin="0,0,0,12">
                    <Border.BorderBrush>#2D3748</Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <!-- Section Label -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <Border Width="3" Height="16"
                                        Background="#F0A500"
                                        CornerRadius="2"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="Property Pictures"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#8B949E"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="+ Add Pictures"
                                    Style="{StaticResource OutlineButton}"
                                    Width="120" Height="28"
                                    FontSize="11"
                                    Click="AddPictures_Click"/>
                        </Grid>

                        <!-- Images List -->
                        <ListBox x:Name="ImagesListBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MaxHeight="220"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 HorizontalContentAlignment="Stretch"
                                 Margin="0,4,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0D1117" 
                                            CornerRadius="6" 
                                            BorderBrush="#2D3748" 
                                            BorderThickness="1" 
                                            Padding="8" 
                                            Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Thumbnail -->
                                            <Border CornerRadius="4" ClipToBounds="True" Height="40" Background="#161B22">
                                                <Image Source="{Binding ImageSource}" Stretch="UniformToFill"/>
                                            </Border>

                                            <!-- Path / Filename -->
                                            <TextBlock Grid.Column="2" 
                                                       Text="{Binding FileName}" 
                                                       Foreground="White" 
                                                       FontSize="12" 
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <!-- Remove Button -->
                                            <Button Grid.Column="3"
                                                    Style="{StaticResource TitlebarButtonStyle}"
                                                    Width="28" Height="28"
                                                    Click="RemovePicture_Click"
                                                    Tag="{Binding}">
                                                <fa:IconImage Icon="Trash" Width="12" Height="12" Foreground="{StaticResource DangerRedBrush}"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <TextBlock x:Name="TxtNoImages" 
                                   Text="No images added yet." 
                                   Foreground="{StaticResource TextMutedBrush}" 
                                   FontSize="12" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,10,0,10"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ROW 2: Bottom action bar (always visible, never scrolls) -->
        <Border Grid.Row="2"
                Background="#161B22"
                BorderBrush="#2D3748"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Hint text left side -->
                <TextBlock Grid.Column="0"
                           Text="* All fields are required"
                           FontSize="11"
                           Foreground="#8B949E"
                           VerticalAlignment="Center"/>

                <!-- Cancel button -->
                <Button Grid.Column="1"
                        Content="Cancel"
                        Style="{StaticResource OutlineButton}"
                        Width="110" Height="38"
                        Click="Cancel_Click"/>

                <!-- Save button -->
                <Button Grid.Column="3"
                        x:Name="SaveBtn"
                        Content="Save Property"
                        Style="{StaticResource PrimaryButton}"
                        Width="140" Height="38"
                        Click="SaveProperty_Click"/>
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>
