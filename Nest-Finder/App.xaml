<Application x:Class="NestFinder.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:NestFinder.Helpers"
             StartupUri="Views/LoginWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- MahApps.Metro Styles -->
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Dark.Teal.xaml" />
                
                <!-- Material Design in XAML -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
                
                <!-- Our Custom Theme and Global Styles -->
                <ResourceDictionary Source="/Styles/GlobalStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Value Converters -->
            <helpers:PaymentStatusBrushConverter x:Key="PaymentStatusBrushConverter"/>
            <helpers:PaymentStatusBgConverter x:Key="PaymentStatusBgConverter"/>
            <helpers:UnpaidToVisibleConverter x:Key="UnpaidToVisibleConverter"/>
            <helpers:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>

            <!-- MahApps Metro custom overrides to match our design system -->
            <SolidColorBrush x:Key="MahApps.Brushes.ThemeBackground" Color="#0D1117" />
            <SolidColorBrush x:Key="MahApps.Brushes.ThemeForeground" Color="#FFFFFF" />
            <SolidColorBrush x:Key="MahApps.Brushes.MetroTextBox.BorderActive" Color="#00FFC8" />
            <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.OnBackground" Color="#00FFC8" />
            <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.OnForeground" Color="#0D1117" />
            <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.OffBackground" Color="#2D3748" />
            <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.ThumbOn" Color="#FFFFFF" />
            <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.ThumbOff" Color="#8B949E" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
