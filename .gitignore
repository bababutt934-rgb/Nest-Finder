## Visual Studio / .NET Core gitignore
## Ignore build artifacts, IDE settings, and local database files

# Build folders
bin/
obj/
[Dd]ebug/
[Rr]elease/
x64/
x86/

# Visual Studio files
.vs/
*.user
*.userosscache
*.sln.docstates

# Rider / IntelliJ IDE
.idea/

# Local databases
*.db
*.sqlite
*.sqlite3

# Environment files
.env
.env.local
.env.*.local

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
